Package: whisper
Title: Native R 'torch' Implementation of 'OpenAI' 'Whisper'
Version: 0.3.0
Authors@R: c(
    person("Troy", "Hernandez", role = c("aut", "cre"),
           email = "troy@cornball.ai"),
